{
  "defaultMode": "plan",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Write",
      "Edit",
      "Read"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx biome check --write \"$CLAUDE_TOOL_INPUT_FILE\" 2>/dev/null",
            "matchFiles": "*.{ts,tsx,js,jsx}"
          }
        ]
      }
    ]
  }
}
